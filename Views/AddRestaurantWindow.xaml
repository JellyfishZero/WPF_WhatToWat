<Window x:Class="WhatToEat.AddRestaurantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WhatToEat"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="新增餐廳" Height="550" Width="800" ResizeMode="NoResize">
    <Window.Resources>
        <x:Array x:Key="HourItems" Type="{x:Type sys:String}">
            <sys:String>00</sys:String>
            <sys:String>01</sys:String>
            <sys:String>02</sys:String>
            <sys:String>03</sys:String>
            <sys:String>04</sys:String>
            <sys:String>05</sys:String>
            <sys:String>06</sys:String>
            <sys:String>07</sys:String>
            <sys:String>08</sys:String>
            <sys:String>09</sys:String>
            <sys:String>10</sys:String>
            <sys:String>11</sys:String>
            <sys:String>12</sys:String>
            <sys:String>13</sys:String>
            <sys:String>14</sys:String>
            <sys:String>15</sys:String>
            <sys:String>16</sys:String>
            <sys:String>17</sys:String>
            <sys:String>18</sys:String>
            <sys:String>19</sys:String>
            <sys:String>20</sys:String>
            <sys:String>21</sys:String>
            <sys:String>22</sys:String>
            <sys:String>23</sys:String>
        </x:Array>

        <x:Array x:Key="MinuteItems" Type="{x:Type sys:String}">
            <sys:String>00</sys:String>
            <sys:String>01</sys:String>
            <sys:String>02</sys:String>
            <sys:String>03</sys:String>
            <sys:String>04</sys:String>
            <sys:String>05</sys:String>
            <sys:String>06</sys:String>
            <sys:String>07</sys:String>
            <sys:String>08</sys:String>
            <sys:String>09</sys:String>
            <sys:String>10</sys:String>
            <sys:String>11</sys:String>
            <sys:String>12</sys:String>
            <sys:String>13</sys:String>
            <sys:String>14</sys:String>
            <sys:String>15</sys:String>
            <sys:String>16</sys:String>
            <sys:String>17</sys:String>
            <sys:String>18</sys:String>
            <sys:String>19</sys:String>
            <sys:String>20</sys:String>
            <sys:String>21</sys:String>
            <sys:String>22</sys:String>
            <sys:String>23</sys:String>
            <sys:String>24</sys:String>
            <sys:String>25</sys:String>
            <sys:String>26</sys:String>
            <sys:String>27</sys:String>
            <sys:String>28</sys:String>
            <sys:String>29</sys:String>
            <sys:String>30</sys:String>
            <sys:String>31</sys:String>
            <sys:String>32</sys:String>
            <sys:String>33</sys:String>
            <sys:String>34</sys:String>
            <sys:String>35</sys:String>
            <sys:String>36</sys:String>
            <sys:String>37</sys:String>
            <sys:String>38</sys:String>
            <sys:String>39</sys:String>
            <sys:String>40</sys:String>
            <sys:String>41</sys:String>
            <sys:String>42</sys:String>
            <sys:String>43</sys:String>
            <sys:String>44</sys:String>
            <sys:String>45</sys:String>
            <sys:String>46</sys:String>
            <sys:String>47</sys:String>
            <sys:String>48</sys:String>
            <sys:String>49</sys:String>
            <sys:String>50</sys:String>
            <sys:String>51</sys:String>
            <sys:String>52</sys:String>
            <sys:String>53</sys:String>
            <sys:String>54</sys:String>
            <sys:String>55</sys:String>
            <sys:String>56</sys:String>
            <sys:String>57</sys:String>
            <sys:String>58</sys:String>
            <sys:String>59</sys:String>
        </x:Array>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="8*" />
            <ColumnDefinition Width="101*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0"
               Grid.Column="0"
               Content="餐廳名稱"
               VerticalAlignment="Top"
               Margin="0,1,16,0" />
        <TextBox x:Name="RestaurantNameTextBox"
                 Grid.Row="0"
                 Grid.Column="1"
                 Height="28"
                 Margin="0,0,0,12" Grid.ColumnSpan="2" />

        <Label Grid.Row="1"
               Grid.Column="0"
               Content="營業時間"
               VerticalAlignment="Top"
               Margin="0,0,16,0" />
        <CheckBox x:Name="HasBusinessHoursCheckBox"
                  Grid.Row="1"
                  Grid.Column="1"
                  Content="需要紀錄營業時間(如不紀錄，則視為ㄧ週七天全天營業)"
                  VerticalAlignment="Top"
                  Margin="0,5,0,0" Grid.ColumnSpan="2" />

        <Label Grid.Row="1"
               Grid.Column="0"
               Content="每週營業時間"
               VerticalAlignment="Top"
               Margin="0,37,16,0" Grid.RowSpan="2" />
        <Grid Grid.Row="1"
              Grid.Column="1"
              Margin="0,37,0,12" Grid.ColumnSpan="2" Grid.RowSpan="2"
              IsEnabled="{Binding IsChecked, ElementName=HasBusinessHoursCheckBox}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="星期" FontWeight="Bold" Margin="0,0,8,8" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="營業" FontWeight="Bold" Margin="0,0,8,8" />
            <TextBlock Grid.Row="0" Grid.Column="2" Text="開始時間" FontWeight="Bold" Margin="0,0,8,8" />
            <TextBlock Grid.Row="0" Grid.Column="3" Text="結束時間" FontWeight="Bold" Margin="0,0,0,8" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="週一" VerticalAlignment="Center" Margin="0,0,8,8" />
            <CheckBox x:Name="MondayOpenCheckBox" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,8" />
            <Grid Grid.Row="1" Grid.Column="2" Margin="0,0,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="MondayStartHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="MondayStartMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>
            <Grid Grid.Row="1" Grid.Column="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="MondayEndHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="MondayEndMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="週二" VerticalAlignment="Center" Margin="0,0,8,8" />
            <CheckBox x:Name="TuesdayOpenCheckBox" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,8" />
            <Grid Grid.Row="2" Grid.Column="2" Margin="0,0,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="TuesdayStartHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="TuesdayStartMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>
            <Grid Grid.Row="2" Grid.Column="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="TuesdayEndHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="TuesdayEndMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="週三" VerticalAlignment="Center" Margin="0,0,8,8" />
            <CheckBox x:Name="WednesdayOpenCheckBox" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,8" />
            <Grid Grid.Row="3" Grid.Column="2" Margin="0,0,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="WednesdayStartHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="WednesdayStartMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>
            <Grid Grid.Row="3" Grid.Column="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="WednesdayEndHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="WednesdayEndMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="週四" VerticalAlignment="Center" Margin="0,0,8,8" />
            <CheckBox x:Name="ThursdayOpenCheckBox" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,8" />
            <Grid Grid.Row="4" Grid.Column="2" Margin="0,0,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ThursdayStartHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="ThursdayStartMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>
            <Grid Grid.Row="4" Grid.Column="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ThursdayEndHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="ThursdayEndMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="週五" VerticalAlignment="Center" Margin="0,0,8,8" />
            <CheckBox x:Name="FridayOpenCheckBox" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,8" />
            <Grid Grid.Row="5" Grid.Column="2" Margin="0,0,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="FridayStartHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="FridayStartMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>
            <Grid Grid.Row="5" Grid.Column="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="FridayEndHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="FridayEndMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="週六" VerticalAlignment="Center" Margin="0,0,8,8" />
            <CheckBox x:Name="SaturdayOpenCheckBox" Grid.Row="6" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,8" />
            <Grid Grid.Row="6" Grid.Column="2" Margin="0,0,8,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SaturdayStartHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="SaturdayStartMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>
            <Grid Grid.Row="6" Grid.Column="3" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SaturdayEndHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="SaturdayEndMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="週日" VerticalAlignment="Center" Margin="0,0,8,0" />
            <CheckBox x:Name="SundayOpenCheckBox" Grid.Row="7" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0" />
            <Grid Grid.Row="7" Grid.Column="2" Margin="0,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SundayStartHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="SundayStartMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>
            <Grid Grid.Row="7" Grid.Column="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SundayEndHourComboBox" Grid.Column="0" Height="28" ItemsSource="{StaticResource HourItems}" SelectedIndex="0" />
                <TextBlock Grid.Column="1" Text=":" VerticalAlignment="Center" Margin="4,0" />
                <ComboBox x:Name="SundayEndMinuteComboBox" Grid.Column="2" Height="28" ItemsSource="{StaticResource MinuteItems}" SelectedIndex="0" />
            </Grid>
        </Grid>

        <Label Grid.Row="3"
               Grid.Column="0"
               Content="喜愛程度"
               VerticalAlignment="Top"
               Margin="0,2,16,0" />
        <Grid Grid.Row="3"
              Grid.Column="1"
              Grid.ColumnSpan="2"
              Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Slider x:Name="PreferenceScoreSlider"
                    Grid.Column="0"
                    Minimum="1"
                    Maximum="5"
                    Value="3"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    TickPlacement="BottomRight"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0" />
            <TextBlock Grid.Column="1"
                       Width="24"
                       Text="{Binding Value, ElementName=PreferenceScoreSlider, StringFormat={}{0:0}}"
                       VerticalAlignment="Center"
                       TextAlignment="Center" />
        </Grid>

        <Button x:Name="AddRestaurantButton"
                Grid.Row="5"
                Grid.Column="2"
                Content="新增"
                Width="96"
                Height="32"
                HorizontalAlignment="Right"
                Click="OnAddNewRestaurantBtnClicked"/>
    </Grid>
</Window>
